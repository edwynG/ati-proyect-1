# Carpetas de laboratorios anteriores (según tu configuración actual)
labs/

# Entornos virtuales de Python
venv/
.venv/
env/
.env

# Archivos compilados de Python (Caché)
__pycache__/
*.py[cod]
*$py.class

# Archivos del sistema operativo (Ocultos)
.DS_Store
Thumbs.db

# Configuraciones de editores de código (VSCode, PyCharm, etc.)
.vscode/
.idea/

# Logs y archivos temporales
*.log
*.tmp
*.bak
*.swp

# Sesiones de Beaker locales (por si alguna vez corres el proyecto fuera de Docker)
sessions/
data/sessions/